# recipes/hacker_news.recipe
# Minimal example: Hacker News top stories via RSS feed
from calibre.web.feeds.news import BasicNewsRecipe

class HackerNews(BasicNewsRecipe):
    title          = 'Hacker News'
    description    = 'Top stories from Hacker News'
    __author__     = 'example'
    language       = 'en'
    oldest_article = 1
    max_articles_per_feed = 20
    auto_cleanup   = True
    no_stylesheets = True
    remove_javascript = True

    feeds = [
        ('Top Stories', 'https://hnrss.org/frontpage'),
    ]
